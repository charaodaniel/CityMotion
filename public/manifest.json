{
  "name": "CityMotion - Gestão Inteligente de Frota",
  "short_name": "CityMotion",
  "description": "Sistema completo de Gestão Inteligente de Frota e Mobilidade Corporativa. Gerencie veículos, funcionários, viagens, manutenção e relatórios em tempo real.",
  "start_url": "/app.html#/dashboard",
  "display": "standalone",
  "background_color": "#09090b",
  "theme_color": "#93c5fd",
  "orientation": "any",
  "categories": ["business", "transportation", "productivity", "utilities"],
  "lang": "pt-BR",
  "scope": "/",
  "id": "/app.html",
  "display_override": ["standalone", "window-controls-overlay"],
  "edge_side_panel": { "preferred_width": 480 },
  "launch_handler": {
    "client_mode": ["navigate-new", "focus-existing"]
  },
  "prefer_related_applications": false,
  "screenshots": [
    {
      "src": "/icons/screenshot-wide.svg",
      "sizes": "1280x720",
      "type": "image/svg+xml",
      "form_factor": "wide",
      "label": "Dashboard da CityMotion com gráficos de frota"
    },
    {
      "src": "/icons/screenshot-narrow.svg",
      "sizes": "720x1280",
      "type": "image/svg+xml",
      "form_factor": "narrow",
      "label": "Visão móvel do painel CityMotion"
    }
  ],
  "icons": [
    {
      "src": "/icons/icon-192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-maskable.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-maskable.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ]
