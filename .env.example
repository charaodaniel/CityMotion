# =============================================================
# CityMotion - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# =============================================================

# --- SEGURANÇA (OBRIGATÓRIO) ---
# Chave secreta para assinatura de tokens JWT.
# Gere uma chave forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# --- SERVIDOR ---
# Porta do backend Express (padrão: 3001).
# No Render, a porta é injetada automaticamente via $PORT.
PORT=3001

# --- BANCO DE DADOS ---
# Modo de persistência: SQLite (padrão) ou PostgreSQL.
# Se DATABASE_URL não estiver definido, o sistema usa SQLite local.
#
# PostgreSQL Local (Docker):
#   DATABASE_URL=postgresql://citymotion_user:citymotion_pass@localhost:5432/citymotion
#
# Render PostgreSQL (automático via Blueprint):
#   Deixe vazio — o Render injeta a connectionString automaticamente.
#
# Supabase:
#   postgresql://postgres:senha@db.seuprojeto.supabase.co:5432/postgres
#
DATABASE_URL=

# --- MODO DEMONSTRAÇÃO ---
# Se definido como 'true', o sistema reseta os dados diariamente (apenas para DEMO).
# NUNCA habilite em produção.
DEMO_MODE=false

# --- ORIGENS PERMITIDAS (CORS) ---
# Lista separada por vírgulas de origens permitidas para o frontend.
# Em produção, defina seu domínio: https://citymotion.seudominio.com
#
# Render:
#   CORS_ORIGIN=https://citymotion.onrender.com
#
CORS_ORIGIN=http://localhost:9002

# --- E-MAIL (SMTP) ---
# Configuração do servidor de e-mail para envio de recuperação de senha.
# Se SMTP_HOST não estiver definido, o sistema usa conta de teste Ethereal.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- RENDER: Configurações específicas (opcional) ---
# Estas variáveis são injetadas automaticamente pelo Render Blueprint.
# Você só precisa defini-las manualmente se estiver configurando fora do Blueprint.
#
# RENDER=true
# RENDER_EXTERNAL_URL=https://citymotion.onrender.com
