{
  "backends": {
    "local-sim": {
      "baseUrl": "http://127.0.0.1:9002/api",
      "description": "API de Simulação Interna (JSON Files)"
    },
    "node-backend": {
      "baseUrl": "http://127.0.0.1:3001/api",
      "description": "Servidor Backend Principal (Node/SQLite)"
    }
  },
  "routes": [
