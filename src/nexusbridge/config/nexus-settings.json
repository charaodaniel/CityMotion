
{
  "backends": {
    "local-sim": {
      "baseUrl": "http://127.0.0.1:9002/api",
      "description": "API de Simulação Interna (JSON Files)"
    },
    "node-backend": {
      "baseUrl": "http://127.0.0.1:3001/api",
      "description": "Servidor Backend Principal (Node/SQLite)"
    }
  },
  "routes": [
    {
      "path": "sync-all",
      "method": "GET",
      "backendId": "node-backend",
      "target": "/data",
      "transformer": "identity"
    },
    {
      "path": "users",
      "method": "GET",
      "backendId": "node-backend",
      "target": "/employees",
      "transformer": "identity"
    },
    {
      "path": "fleet",
      "method": "GET",
      "backendId": "node-backend",
      "target": "/vehicles",
      "transformer": "identity"
    },
    {
      "path": "auth/login",
      "method": "POST",
      "backendId": "node-backend",
      "target": "/login",
      "transformer": "auth"
    },
    {
      "path": "test/db-employees",
      "method": "GET",
      "backendId": "node-backend",
      "target": "/employees",
      "transformer": "identity"
    },
    {
      "path": "test/db-employees",
      "method": "POST",
      "backendId": "node-backend",
      "target": "/employees",
      "transformer": "identity"
    },
    {
      "path": "test/db-employees",
      "method": "PUT",
      "backendId": "node-backend",
      "target": "/employees",
      "transformer": "identity"
    },
    {
      "path": "test/db-employees",
      "method": "DELETE",
      "backendId": "node-backend",
      "target": "/employees",
      "transformer": "identity"
    },
    {
      "path": "test/db-vehicles",
      "method": "GET",
      "backendId": "node-backend",
      "target": "/vehicles",
      "transformer": "identity"
    },
    {
      "path": "maintenance/db-reset",
      "method": "POST",
      "backendId": "node-backend",
      "target": "/maintenance/reset",
      "transformer": "identity"
    },
    {
      "path": "system/resources",
      "method": "GET",
      "backendId": "node-backend",
      "target": "/system/resources",
      "transformer": "identity"
    },
    {
      "path": "system/db-info",
      "method": "GET",
      "backendId": "node-backend",
      "target": "/system/db-info",
      "transformer": "identity"
    }
  ]
}
