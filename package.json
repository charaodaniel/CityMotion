{
  "name": "citymotion",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "npm run db:init && concurrently -k -n \"FRONT,BACK\" -c \"blue,green\" \"npm:dev:frontend\" \"npm:dev:backend\"",
    "dev:frontend": "npx kill-port 9002 || true; sleep 2; next dev --turbopack -p 9002",
    "build:spa": "npx tailwindcss -c tailwind.public.config.js -i ./public/css/input.css -o ./public/css/tailwind.css --minify",
    "dev:backend": "cd backend && (npx kill-port 3001 || true) && npm run dev",
    "genkit:dev": "genkit start -- node src/ai/dev.js",
    "genkit:watch": "genkit start -- node --watch src/ai/dev.js",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently -k \"npm:dev:frontend\" \"npm:dev:backend\" \"npm:electron\"",
    "electron": "wait-on tcp:9002 && electron .",
    "dev-server": "npm run dev:backend",
    "db:init": "cd backend && npm run db:init",
    "test:frontend": "vitest run --config tests/vitest.config.js",
    "test:frontend:watch": "vitest --config tests/vitest.config.js"
  },
  "dependencies": {
    "@genkit-ai/google-genai": "^1.20.0",
    "@genkit-ai/next": "^1.20.0",
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.19.2",
    "framer-motion": "^11.11.11",
    "genkit": "^1.39.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.475.0",
    "next": "15.3.8",
    "nodemailer": "^6.9.13",
    "patch-package": "^8.0.0",
    "pg": "^8.11.5",
    "qrcode.react": "^3.1.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-leaflet": "^4.2.1",
    "recharts": "^2.15.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "wait-on": "^7.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.10",
    "electron": "^31.2.1",
    "electron-builder": "^25.0.0",
    "genkit-cli": "^1.20.0",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "vitest": "^4.1.10"
  }
}
